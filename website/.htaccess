Options -Indexes
DirectoryIndex index.php

# Obsolete patch-era endpoints and archives must never be served. v0.1.7 uses
# one complete Python installer and the normal anonymous game API only.
<FilesMatch "^(download\.php|tulipwars_files\.php|.*\.(tar|tar\.gz|tgz))$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer"
    Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>
